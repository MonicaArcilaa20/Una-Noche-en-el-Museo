  m_GameObject: {fileID: 463239101}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ce82b8ce214bd14aa01cbba822599ec, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MuseoFlowManager
  canvasControlesMovimiento: {fileID: 2009598500}
  canvasControlesPincel: {fileID: 39751434}
  panelSubtitulos: {fileID: 1304565608}
  textoSubtitulos: {fileID: 879207436}
  senaleticaPasilloIzquierdo: {fileID: 783908167}
  senaleticaPasilloDerecho: {fileID: 90921205}
  senaleticaPrimerCuadro: {fileID: 1480454527}
  audioSourceVoz: {fileID: 463239103}
  vozIntro1: {fileID: 8300000, guid: 16fba6d30ed741d4a9fdd6e79ee2f3ac, type: 3}
  vozIntro2: {fileID: 8300000, guid: 1d4249496684ff544b54719d7f07e727, type: 3}
  vozIntro3: {fileID: 8300000, guid: 16fba6d30ed741d4a9fdd6e79ee2f3ac, type: 3}
  vozPincelEncontrado: {fileID: 8300000, guid: 1d4249496684ff544b54719d7f07e727, type: 3}
  vozPincelPoder: {fileID: 8300000, guid: 16fba6d30ed741d4a9fdd6e79ee2f3ac, type: 3}
  vozBuscarTinta: {fileID: 8300000, guid: 1d4249496684ff544b54719d7f07e727, type: 3}
  vozTintaTomada: {fileID: 8300000, guid: 16fba6d30ed741d4a9fdd6e79ee2f3ac, type: 3}
  vozPintarPrimerCuadro: {fileID: 8300000, guid: 1d4249496684ff544b54719d7f07e727, type: 3}
  vozEntrarAlCuadro: {fileID: 8300000, guid: 16fba6d30ed741d4a9fdd6e79ee2f3ac, type: 3}
  textoIntro1: "Bienvenido al lado del museo que nunca has visto. Un museo fuera
    de lo com\xFAn."
  textoIntro2: "Este museo no es lo que parece. Las pinturas pueden parecer s\xF3lo
    representaciones visuales de imaginarios individuales, pero si observamos con
    suficiente detenimiento, notaremos que a veces, en algunos rincones, estas pinturas
    parecen cobrar vida\u2026"
  textoIntro3: "Explora el lugar y encuentra el Pincel M\xE1gico que te permitir\xE1
    abrir nuevos mundos y te acompa\xF1ar\xE1 durante todo el viaje."
  textoPincelEncontrado: "\xA1Has encontrado el Pincel M\xE1gico!"
  textoPincelPoder: "Ahora posees el poder de visitar los mundos posibles de las
    obras de este m\xE1gico lugar."
  textoBuscarTinta: "Pero ten cuidado, necesitar\xE1s de tinta para activar los portales
    en cada mundo, busca tu primera carga de tinta y emb\xE1rcate en esta art\xEDstica
    aventura."
  textoTintaTomada: "\xA1Ahora tienes todo lo que se necesita para pintar tu primer
    cuadro! Activa el cuadro y observa c\xF3mo sucede la magia."
  textoPintarPrimerCuadro: "Ahora tienes todo lo que se necesita para pintar tu primer
    cuadro. El pincel no dibuja lo que ves, dibuja lo que es posible. Pinta el marco
    y observa c\xF3mo sucede la magia."
  textoEntrarAlCuadro: "Observa la magia, mira c\xF3mo el cuadro cobra vida y te
    extiende una invitaci\xF3n a entrar. No tengas miedo. Posibles mundos esperan
    por ti para ser vistos y transformados."
  duracionCanvasMovimiento: 8
  duracionCanvasPincel: 8
  pausaEntreLineas: 1
  duracionFallbackLinea: 4.5
